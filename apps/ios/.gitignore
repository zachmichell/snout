# Build products and derived data
build/
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/


# Local secrets — committed as Config.example.plist instead
Snout/Resources/Config.plist
GoogleService-Info.plist

# Apple cruft
.DS_Store
xcuserdata/
*.xcuserstate

# Swift Package Manager artifacts (resolved dependencies cached locally).
# Note: we intentionally COMMIT the workspace-level Package.resolved so
# Xcode Cloud has the pinned dependency tree to resolve from. Ignoring
# every Package.resolved indiscriminately is what broke the Xcode Cloud
# build with "automatic dependency resolution is disabled" errors.
.swiftpm/
.build/
# Ignore SPM resolved files inside checkouts (build artifacts), but NOT
# the workspace-level one.
**/SourcePackages/**/Package.resolved
**/checkouts/**/Package.resolved

# fastlane (future)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Push Notifications capability for the staff app. Not yet wired into the
	  target (CODE_SIGN_ENTITLEMENTS) because the project builds unsigned
	  (no Apple Developer team configured). When signing is set up:
	    1. Enable Push Notifications on the org.snoutapp.snoutstaff App ID.
	    2. Add `CODE_SIGN_ENTITLEMENTS: SnoutStaff/Resources/SnoutStaff.entitlements`
	       to the SnoutStaff target settings in project.yml.
	    3. Switch aps-environment to "production" for App Store / TestFlight.
	-->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
